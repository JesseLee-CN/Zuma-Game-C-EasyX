{
    "tasks": [
        {
            "type": "cppbuild",
            "label": "C/C++: g++ build Zuma Game",
            "command": "g++",
            "args": [
                "-fdiagnostics-color=always",
                "-g",
                "-Wall",
                "-Wextra",
                "${workspaceFolder}\\src\\*.cpp",
                "-I${workspaceFolder}\\include",
                "-o",
                "${workspaceFolder}\\build\\ZumaGame.exe",
                "-leasyx",
                "-lgdi32"
            ],
            "options": {
                "cwd": "${workspaceFolder}"
            },
            "problemMatcher": [
                "$gcc"
            ],
            "group": {
                "kind": "build",
                "isDefault": true
            },
            "detail": "Build Zuma Game with EasyX"
        }
    ],
    "version": "2.0.0"
}
